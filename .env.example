# Copy this file to .env and fill in real values. Never commit .env.
# On Render, set these as env vars in the service dashboard instead.

# --- Power BI service principal ---
# Azure tenant GUID
PBI_TENANT_ID=3be3af3c-46a1-461d-93b1-44954da5e032
# App (client) ID of the service principal
PBI_CLIENT_ID=191260ff-ab3f-4d75-a211-780754200954
# Service principal secret value (NOT the secret ID)
PBI_CLIENT_SECRET=

# --- Power BI dataset location ---
PBI_WORKSPACE_ID=5c32a84f-0b3d-406c-9097-4930093e3005
PBI_DATASET_ID=6b189299-794b-4a70-8bc9-8c2d269871ca
# Required when the target dataset has RLS and we call via service principal.
# Value is a UPN (user email) of someone with dataset access — usually an admin.
PBI_IMPERSONATED_USER=

# --- Excellence Standards MySQL (replaces excellence_export.php) ---
MYSQL_HOST=haleglobal.com
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# --- Pipeline API auth (server and local client use this) ---
# Any long random string; local clients present it as a bearer token.
PIPELINE_API_TOKEN=

# --- Local client only ---
# Where scripts/pull_local.py writes the xlsx (one folder created per Key3).
LOCAL_RESPONDENT_ROOT=
# Base URL of the deployed Render service (for pull_local.py).
PIPELINE_URL=
